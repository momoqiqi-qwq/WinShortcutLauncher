{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Win Shortcut Launcher",
  "version": "0.1.44",
  "identifier": "com.ava.win-shortcut-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Win Shortcut Launcher",
        "width": 980,
        "height": 660,
        "minWidth": 8,
        "minHeight": 8,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/launcher_new_256.png",
      "icons/launcher_new_512.png",
      "icons/launcher_new.ico"
    ]
  }
}
